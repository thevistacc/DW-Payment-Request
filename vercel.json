{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "sw.js", "use": "@vercel/static" },
    { "src": "app.webmanifest", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/sw.js",
      "dest": "/sw.js",
      "headers": {
        "Service-Worker-Allowed": "/",
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "/app.webmanifest",
      "dest": "/app.webmanifest",
      "headers": { "Content-Type": "application/manifest+json" }
    },
    {
      "src": "/manifest.json",
      "dest": "/app.webmanifest",
      "headers": { "Content-Type": "application/manifest+json" }
    },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
